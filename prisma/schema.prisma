// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Use an Enum for better code clarity
enum LogLevel {
  INFO
  WARN
  ERROR
  DEBUG
}

model user {
  id        BigInt    @id @default(autoincrement())
  email     String    @unique
  name      String?
  password  String
  timestamp DateTime  @default(now())
  projects  project[]
  sessions  session[]
}

model project {
  id          BigInt    @id @default(autoincrement())
  name        String
  description String?
  user_id     BigInt
  user        user      @relation(fields: [user_id], references: [id])
  timestamp   DateTime  @default(now())
  api_keys    api_key[]
}

model api_key {
  id         BigInt   @id @default(autoincrement())
  key        String   @unique // This is the actual string used in headers
  project_id BigInt
  project    project  @relation(fields: [project_id], references: [id])
  status     Int      @default(0) // 0 = active, 1 = revoked
  timestamp  DateTime @default(now())
  logs       log[]
}

model log {
  // Use BigInt for massive scale performance
  id         BigInt   @id @default(autoincrement())
  api_key_id BigInt
  api_key    api_key  @relation(fields: [api_key_id], references: [id])
  message    String
  metadata   Json // Perfect for your 'JSONB' storage
  level      LogLevel @default(INFO)
  timestamp  DateTime @default(now())

  // CRITICAL: Composite index for fast dashboard queries
  @@index([api_key_id, timestamp])
}

model session {
  id         BigInt   @id @default(autoincrement())
  user_id    BigInt
  user       user     @relation(fields: [user_id], references: [id])
  session_id String
  timestamp  DateTime @default(now())
  user_agent String
}
